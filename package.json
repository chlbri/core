{
  "name": "@bemedev/core",
  "version": "0.5.0",
  "description": "The core library of @bemedev, providing essential functionalities and utilities for the Bemedev ecosystem.",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/core.git"
  },
  "bin": "lib/scripts/cli/index.js",
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "core",
    "bemedev",
    "@bemedev",
    "functions",
    "utilities",
    "typings"
  ],
  "files": [
    "lib",
    "public",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "_preconfig": "chmod -x \".husky/commit-msg\"",
    "build": "pnpm run rm:lib && pnpm run rolldown && pnpm run codegen",
    "build:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run build",
    "ci": "CI_START=$(date +%s) && pnpm run config:off && pnpm run lint && pnpm run test && pnpm run p-q && echo \"\n✅ CI takes $(($(date +%s) - CI_START))s\n\"",
    "ci:admin": "pnpm run rm && pnpm --prefix ./example run rm && pnpm run upgrade:fast && pnpm --prefix ./example run upgrade && pnpm run ci",
    "clean": "pnpm run rm && pnpm run config",
    "codegen": "pnpm codebase -x \"src/**/*.test-d.ts\" -x \"src/scripts/**/*\"",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:fix": "oxlint --fix",
    "lint:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run lint",
    "manifest": "tsx src/scripts/manifest/generate.ts",
    "p-q": "pretty-quick",
    "posttest": "pnpm run test:cli && pnpm run fmt",
    "prepare": "husky",
    "prepublishOnly": "",
    "pretest": "pnpm run build && pnpm run size",
    "rinit": "pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rimraf": "pnpm dlx rimraf -rf",
    "rm": "pnpx rimraf ./node_modules ./pnpm-lock.yaml",
    "rm:lib": "pnpx rimraf ./lib",
    "rolldown": "rolldown -c",
    "size": "size-limit",
    "test": "pnpm run test:coverage",
    "test:cli": "pnpm --prefix ./example run test",
    "test:coverage": "vitest run",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "upgrade": "pnpm dlx @bemedev/upgrade-npm-package",
    "upgrade:fast": "pnpm up --latest"
  },
  "size-limit": [
    {
      "path": "lib/*.js",
      "limit": "10 KB"
    },
    {
      "path": "lib/*.cjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@bemedev/dev-utils": "^0.6.6",
    "@bemedev/fsf": "^1.0.1",
    "@bemedev/vitest-alias": "^0.0.3",
    "@bemedev/vitest-exclude": "^0.1.1",
    "@bemedev/vitest-extended": "^1.5.3",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@size-limit/file": "^12.1.0",
    "@types/edit-json-file": "1.7.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "4.1.5",
    "eslint": "10.3.0",
    "glob": "^13.0.6",
    "globals": "17.6.0",
    "husky": "^9.1.7",
    "onchange": "^7.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "prettier": "3.8.3",
    "pretty-quick": "^4.2.2",
    "rolldown": "1.0.0-rc.18",
    "rollup": "4.60.2",
    "size-limit": "^12.1.0",
    "tslib": "^2.8.1",
    "tsx": "4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@bemedev/codebase": "^0.3.0",
    "@bemedev/sleep": "^0.2.2",
    "chokidar": "^5.0.0",
    "cmd-ts": "0.15.0",
    "edit-json-file": "^1.8.1",
    "ts-morph": "28.0.0",
    "valibot": "1.3.1"
  }
}
