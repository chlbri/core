{
  "name": "@core/core",
  "version": "0.0.23",
  "description": "The additional types",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "author": "core_chlbri",
  "license": "MIT",
  "private": false,
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=12"
  },
  "scripts": {
    "tsc": "tsc",
    "build": "pnpm run test && pnpm run tsc && pnpm run lint",
    "build:-test": "pnpm run tsc && pnpm run lint",
    "test": "jest",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "eslint": "eslint \"{src/**/*,App}.{ts,tsx,yml,json}\"",
    "lint": "pnpm run prettier && pnpm run eslint -- --fix",
    "rm": "rimraf -rf node_modules pnpm.lock",
    "rinit": "pnpm run rm && pnpm cache clean && pnpm run pnpm",
    "publish": "pnpm run rm && pnpm run clean && pnpm run pnpm",
    "clean": "pnpm cache clean",
    "pnpm": "pnpm install",
    "upgrade": "pnpm upgrade",
    "git-push": "git push --follow-tags",
    "git-build-push": "pnpm install && pnpm build && pnpm run git-push",
    "git-publish": "pnpm run git-build-push && git checkout main && git merge dev && pnpm run git-push && git checkout dev"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@types/faker": "^5.5.8",
    "@types/jest": "^27.0.2",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "dayjs": "^1.10.7",
    "edit-json-file": "^1.6.0",
    "eslint": "^7.32.0",
    "faker": "^5.5.3",
    "immer": "^9.0.6",
    "jest": "^27.2.5",
    "jest-cucumber": "^3.0.1",
    "jest-extended": "^1.0.0",
    "nanoid": "^3.1.29",
    "prettier": "^2.4.1",
    "rimraf": "^3.0.2",
    "shelljs": "^0.8.4",
    "ts-jest": "^27.0.5",
    "typescript": "^4.4.3"
  }
}
