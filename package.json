{
  "name": "@bemedev/core",
  "version": "0.0.1",
  "description": "The additional types",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "author": "chlbri",
  "license": "MIT",
  "private": false,
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=12"
  },
  "scripts": {
    "build": "rm -rf lib && rollup -c",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "eslint": "eslint \"{src/**/*,App}.{ts,tsx,yml,json}\"",
    "lint": "pnpm run prettier && pnpm run eslint --fix",
    "lint:watch": "onchange -d 1000 --await-write-finish 5500 \"**/*\" -- pnpm run lint",
    "pnpm": "pnpm install",
    "update": "pnpm update",
    "clean": "rm -rf node_modules pnpm-lock.yaml && pnpm i"
  },
  "dependencies": {
    "dequal": "^2.0.3",
    "nanoid": "^4.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.36.1",
    "@typescript-eslint/parser": "^5.36.1",
    "dayjs": "^1.11.5",
    "edit-json-file": "^1.7.0",
    "esbuild": "^0.15.6",
    "eslint": "^8.23.0",
    "immer": "^9.0.15",
    "onchange": "^7.1.0",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "rollup": "^2.79.0",
    "rollup-plugin-dts": "^4.2.2",
    "rollup-plugin-esbuild": "^4.10.1",
    "rollup-plugin-terser": "^7.0.2",
    "shelljs": "^0.8.5",
    "typescript": "^4.8.2",
    "vite": "^3.0.9",
    "vitest": "^0.22.1"
  },
  "wallaby": {
    "slowTestThreshold": 200,
    "runMode": "onsave",
    "delays": {
      "run": 500
    },
    "trace": true
  }
}
